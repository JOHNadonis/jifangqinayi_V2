# 数据库配置
DATABASE_URL="postgresql://postgres:password@localhost:5432/dc_visualizer?schema=public"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 应用配置
PORT=3001
NODE_ENV=development

# 文件上传配置
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# AI配置 (可选，用于智能补全)
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
