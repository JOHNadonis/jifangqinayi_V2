// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户管理 ====================

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  password       String
  name           String?
  role           String          @default("USER")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  projectMembers ProjectMember[]

  @@map("users")
}

// ==================== 项目管理 ====================

model Project {
  id           String          @id @default(uuid())
  name         String
  description  String?
  inviteCode   String          @unique @map("invite_code")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  members      ProjectMember[]
  rooms        Room[]
  racks        Rack[]
  devices      Device[]
  cables       Cable[]
  templates    DeviceTemplate[]
  activityLogs ActivityLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now()) @map("joined_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ==================== 操作日志 ====================

model ActivityLog {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  username   String
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  entityName String?  @map("entity_name")
  before     String?
  after      String?
  createdAt  DateTime @default(now()) @map("created_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model ErrorLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  username   String?
  method     String
  path       String
  statusCode Int      @map("status_code")
  message    String
  stack      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}

// ==================== 机房管理 ====================

model Room {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  location    String
  type        String   @default("OLD")
  description String?
  racks       Rack[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rooms")
}

// ==================== 机柜管理 ====================

model Rack {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  roomId      String   @map("room_id")
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  totalU      Int      @default(42) @map("total_u")
  row         Int?
  column      Int?
  location    String?
  description String?
  devices     Device[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("racks")
}

// ==================== 设备模板 ====================

model DeviceTemplate {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brand      String
  model      String
  sizeU      Int      @map("size_u")
  deviceType String   @map("device_type")
  frontImage String?  @map("front_image")
  rearImage  String?  @map("rear_image")
  portLayout String   @default("{}") @map("port_layout")
  isPublic   Boolean  @default(false) @map("is_public")
  devices    Device[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("device_templates")
}

// ==================== 设备管理 ====================

model Device {
  id         String         @id @default(uuid())
  projectId  String         @map("project_id")
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  assetTag   String?        @map("asset_tag")
  templateId String         @map("template_id")
  template   DeviceTemplate @relation(fields: [templateId], references: [id])
  rackId     String?        @map("rack_id")
  rack       Rack?          @relation(fields: [rackId], references: [id], onDelete: SetNull)
  positionU  Int?           @map("position_u")
  status     String         @default("ONLINE")
  notes      String?
  cablesFrom Cable[]        @relation("CableSource")
  cablesTo   Cable[]        @relation("CableDestination")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@map("devices")
}

// ==================== 连线管理 ====================

model Cable {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  traceCode    String   @unique @map("trace_code")
  srcDeviceId  String   @map("src_device_id")
  srcDevice    Device   @relation("CableSource", fields: [srcDeviceId], references: [id], onDelete: Cascade)
  srcPortIndex String   @map("src_port_index")
  dstDeviceId  String   @map("dst_device_id")
  dstDevice    Device   @relation("CableDestination", fields: [dstDeviceId], references: [id], onDelete: Cascade)
  dstPortIndex String   @map("dst_port_index")
  cableType    String   @map("cable_type")
  color        String?
  length       Float?
  purpose      String?
  photoUrl     String?  @map("photo_url")
  status       String   @default("RECORDED")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("cables")
}

// ==================== 同步记录 ====================

model SyncLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  data       String?
  clientId   String   @map("client_id")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@map("sync_logs")
}
